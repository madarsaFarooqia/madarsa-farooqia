# Copy to `.env.development.local` when you need these (Create React App).

# Mock API (see src/mocks/README.txt). In development, mocks are ON by default.
# Set to false when your backend is running on this machine.
# REACT_APP_USE_MOCK_API=false

# With mocks: pretend logged-in user is admin (needs a token in localStorage — see README).
# REACT_APP_MOCK_USER_ROLE=admin

# Base URL for your API (empty = same origin as the React dev server, e.g. /api/... )
# REACT_APP_API_URL=http://localhost:4000

# When your backend exposes GET /api/public/settings, set to true so the app fetches it on startup.
# Default is false so the UI works with no backend connected.
# REACT_APP_FETCH_PUBLIC_SETTINGS=true

# After login, only redirect to login on 401/403 when this is true (strict production).
# Default is false: invalid/expired token is cleared and the site stays usable offline.
# REACT_APP_ENFORCE_AUTH_GATE=true

# Optional: milliseconds for GET /api/auth/me when a token exists (default 8000).
# REACT_APP_AUTH_ME_TIMEOUT_MS=8000
